{
  "name": "openshell-node",
  "version": "0.1.0",
  "description": "TypeScript gRPC client for NVIDIA OpenShell sandboxes",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./generated": {
      "types": "./dist/generated/index.d.ts",
      "import": "./dist/generated/index.js",
      "require": "./dist/generated/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "proto",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "author": "Moonshot Partners",
  "repository": {
    "type": "git",
    "url": "https://github.com/moonshot-partners/openshell-node"
  },
  "homepage": "https://github.com/moonshot-partners/openshell-node#readme",
  "bugs": "https://github.com/moonshot-partners/openshell-node/issues",
  "keywords": [
    "openshell",
    "nvidia",
    "grpc",
    "sandbox",
    "container",
    "agent",
    "ai",
    "typescript"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:integration": "OPENSHELL_TEST=1 vitest run --config vitest.integration.config.ts",
    "lint": "eslint src/ --ignore-pattern 'src/generated/'",
    "lint:fix": "eslint src/ --fix --ignore-pattern 'src/generated/'",
    "format": "prettier --write 'src/**/*.ts' '!src/generated/**' '*.json' '*.md'",
    "format:check": "prettier --check 'src/**/*.ts' '!src/generated/**' '*.json' '*.md'",
    "generate": "./scripts/generate-protos.sh",
    "prepublishOnly": "pnpm build",
    "prepare": "husky"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "nice-grpc": "^2.1.14",
    "nice-grpc-common": "^2.0.2"
  },
  "peerDependencies": {
    "@bufbuild/protobuf": ">=2.0.0"
  },
  "devDependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "prettier": "^3.5.3",
    "ts-proto": "^2.11.5",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vitest": "^3.2.1"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix --ignore-pattern 'src/generated/'",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "protobufjs"
    ]
  }
}
